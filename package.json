{
  "name": "@blognews/backend",
  "version": "1.0.0",
  "description": "AI-powered News Platform - AWS Serverless Backend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rimraf dist && tsc",
    "watch": "tsc --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --passWithNoTests",
    "sam:build": "sam build",
    "sam:invoke": "sam local invoke",
    "sam:start-api": "sam local start-api",
    "sam:deploy": "sam deploy",
    "local:collect-news": "tsx scripts/run-collect-news.ts",
    "local:process-news": "tsx scripts/run-process-news.ts",
    "local:publish-article": "tsx scripts/run-publish-article.ts",
    "local:health": "tsx scripts/run-health-check.ts",
    "source:create": "tsx scripts/run-source-create.ts",
    "source:list": "tsx scripts/run-source-list.ts",
    "source:get": "tsx scripts/run-source-get.ts",
    "source:update": "tsx scripts/run-source-update.ts",
    "source:delete": "tsx scripts/run-source-delete.ts",
    "source:toggle": "tsx scripts/run-source-toggle.ts",
    "article:create": "tsx scripts/run-article-create.ts",
    "article:list": "tsx scripts/run-article-list.ts",
    "article:get": "tsx scripts/run-article-get.ts",
    "article:update": "tsx scripts/run-article-update.ts",
    "rss:test": "tsx scripts/run-rss-validation.ts",
    "content:test": "tsx scripts/test-content-fetcher.ts",
    "collect:pipeline:test": "tsx scripts/test-collector-pipeline.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-eventbridge": "^3.700.0",
    "@aws-sdk/client-rekognition": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@aws-sdk/util-dynamodb": "^3.700.0",
    "@extractus/article-extractor": "8.1.0",
    "rss-parser": "3.13.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.146.0",
    "@types/jest": "^29.5.14",
    "@types/node": "22.20.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "aws-lambda": "1.0.6",
    "eslint": "^9.15.0",
    "husky": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
